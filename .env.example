# 数据库路径（可选，默认 data/etf_assistant.db）
DATABASE_PATH=data/etf_assistant.db

# 配置文件路径（可选，默认 config/app.yaml）
CONFIG_PATH=config/app.yaml

# 行情数据源：auto | akshare | mock
PRICE_DATA_SOURCE=auto

# AI 复盘（阶段 8）
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=
LLM_TIMEOUT=60

# DeepSeek 示例：
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://api.deepseek.com
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-v4-flash
# LLM_TIMEOUT=60

# 邮件通知（阶段 13.1）
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.163.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=false
EMAIL_SMTP_USE_SSL=true
EMAIL_FROM=
EMAIL_TO=
EMAIL_TIMEOUT=30

NOTIFY_ON_SCHEDULER_FAILURE=true
NOTIFY_ON_SCHEDULER_SUCCESS=false
NOTIFY_ON_HIGH_PRIORITY_TASKS=true
NOTIFY_ON_PORTFOLIO_RISK=true
NOTIFY_ON_DAILY_PIPELINE_DONE=false
