# 数据库路径（可选，默认 data/etf_assistant.db）
DATABASE_PATH=data/etf_assistant.db

# 配置文件路径（可选，默认 config.yaml）
CONFIG_PATH=config.yaml

# 行情数据源：auto | akshare | mock
PRICE_DATA_SOURCE=auto

# AI 复盘（阶段 8）
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=
LLM_TIMEOUT=60

# DeepSeek 示例：
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://api.deepseek.com
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-v4-flash
# LLM_TIMEOUT=60
